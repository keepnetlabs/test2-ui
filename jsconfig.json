{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ],
            "@components/*": [
                "src/components/*"
            ],
            "@utils/*": [
                "src/utils/*"
            ]
        },
        "target": "ES6",
        "lib": [
            "ES2015",
            "ES2017",
            "ES2018",
            "ES2019",
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "skipLibCheck": true,
        "module": "commonjs",
        "allowSyntheticDefaultImports": true,
        "experimentalDecorators": true,
        "allowJs": true,
        "checkJs": false,
        "jsx": "preserve",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "esModuleInterop": true
    },
    "vueCompilerOptions": {
        "experimentalCompatMode": 2,
        "extensions": [".vue", ".js", ".ts", ".jsx", ".tsx"]
    },
    "exclude": [
        "node_modules",
        "dist",
        "src/assets/scss/**/*"
    ],
    "include": [
        "src/**/*.js",
        "src/**/*.vue",
        "src/**/*.ts"
    ]
}