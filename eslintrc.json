{
  "parserOptions": {
    "ecmaVersion": 6,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "prettier/prettier": [
    "warn",
    {
      "#": "prettier config in here :)",
      "singleQuote": true,
      "semi": false,
      "trailingComma": "none",
      "no-unused-vars": false,
      "vue/no-use-v-if-with-v-for": [
        "none",
        {
          "allowUsingIterationVar": false
        }
      ],
      "vue/require-v-for-key": "none"
    }
  ]
}
