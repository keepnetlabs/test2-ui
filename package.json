{
  "name": "keep-net-vue",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build",
    "lint": "vue-cli-service lint",
    "format": "vue-cli-service lint --fix",
    "storybook:build": "vue-cli-service storybook:build -c config/storybook",
    "storybook:serve": "vue-cli-service storybook:serve -p 6006 -c config/storybook"
  },
  "dependencies": {
    "@babel/polyfill": "^7.10.1",
    "@fullstory/browser": "^1.4.5",
    "@mdi/font": "^5.4.55",
    "apexcharts": "^3.10.1",
    "axios": "^0.19.0",
    "babel-polyfill": "^6.26.0",
    "core-js": "^3.6.5",
    "echarts": "^4.3.0",
    "echarts-gl": "^1.1.1",
    "grapesjs": "^0.16.18",
    "grapesjs-blocks-avance": "0.0.32",
    "grapesjs-blocks-basic": "^0.1.8",
    "grapesjs-custom-code": "^0.1.3",
    "grapesjs-parser-postcss": "^0.1.1",
    "grapesjs-plugin-export": "^1.0.7",
    "grapesjs-preset-newsletter": "^0.2.20",
    "grapesjs-preset-webpage": "^0.1.11",
    "image-to-blob": "^0.2.0",
    "js-cookie": "^2.2.1",
    "jszip": "^3.4.0",
    "pdfmake": "^0.1.63",
    "print-js": "^1.0.63",
    "v-mask": "^2.2.3",
    "v-offline": "^1.1.0",
    "vue": "^2.6.10",
    "vue-analytics": "^5.22.1",
    "vue-apexcharts": "^1.5.1",
    "vue-clamp": "^0.2.2",
    "vue-custom-element": "^3.2.14",
    "vue-echarts": "^4.0.4",
    "vue-hotjar": "^1.2.0",
    "vue-moment": "^4.1.0",
    "vue-query-builder": "^0.8.2",
    "vue-recaptcha": "^1.2.0",
    "vue-router": "^3.3.4",
    "vue-smart-widget": "^0.5.5",
    "vue-tour": "^1.1.0",
    "vue-upload-component": "^2.8.20",
    "vuedraggable": "^2.23.2",
    "vuetify": "^2.3.0",
    "vuex": "^3.4.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.10.2",
    "@storybook/addon-actions": ">=5.3.0",
    "@storybook/addon-docs": ">=5.3.0",
    "@storybook/addon-knobs": ">=5.3.0",
    "@storybook/addon-links": ">=5.3.0",
    "@storybook/addon-notes": ">=5.3.0",
    "@storybook/vue": ">=5.3.0",
    "@vue/cli-plugin-babel": "^4.4.4",
    "@vue/cli-plugin-eslint": "^4.4.4",
    "@vue/cli-service": "^4.4.4",
    "@vue/eslint-config-prettier": "^6.0.0",
    "babel-eslint": "^10.1.0",
    "deepmerge": "^4.0.0",
    "element-ui": "^2.13.2",
    "es-check": "^5.0.0",
    "eslint": "^6.7.2",
    "eslint-plugin-prettier": "^3.1.3",
    "eslint-plugin-vue": "^6.2.2",
    "fibers": "^5.0.0",
    "node-sass": "^4.14.1",
    "prettier": "2.0.5",
    "prettier-eslint": "^10.1.1",
    "prettier-eslint-cli": "^5.0.0",
    "sass": "^1.26.7",
    "sass-loader": "^8.0.2",
    "vue-class-component": "^7.1.0",
    "vue-cli-plugin-storybook": "~1.2.2",
    "vue-cli-plugin-vuetify": "^2.0.5",
    "vue-template-compiler": "^2.6.10",
    "vuetify-loader": "^1.5.0",
    "webpack": "^4.43.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "browser": true,
      "node": true
    },
    "plugins": [
      "vue",
      "prettier"
    ],
    "extends": [
      "plugin:vue/essential",
      "@vue/prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "warn",
        {
          "#": "prettier config in here :)",
          "semi": false,
          "singleQuote": true,
          "trailingComma": "none",
          "no-unused-vars": false,
          "vue/require-v-for-key": false
        }
      ],
      "vue/no-use-v-if-with-v-for": "off"
    },
    "parserOptions": {
      "parser": "babel-eslint",
      "ecmaVersion": 6,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ]
}
