    "eslint-plugin-vue": "7.20.0",
    "jest-canvas-mock": "^2.3.1",
    "node-sass": "6.0.1",
    "prettier": "2.0.5",
    "prettier-eslint": "^10.1.1",
    "prettier-eslint-cli": "^5.0.0",
    "sass": "1.26.11",
    "sass-loader": "10.5.2",
