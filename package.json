    "@vue/cli-plugin-eslint": "4.5.6",
    "@vue/cli-plugin-unit-jest": "4.5.6",
    "@vue/cli-service": "4.5.6",
    "@vue/eslint-config-prettier": "^6.0.0",
    "@vue/test-utils": "^1.2.0",
    "babel-eslint": "^10.1.0",
    "deepmerge": "^4.0.0",
    "element-ui": "2.15.6",
    "es-check": "^5.0.0",
