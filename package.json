    "vue-template-babel-compiler": "^2.0.0",
    "vue-template-compiler": "2.7.8",
    "vuetify-loader": "1.9.2",
    "webpack": "^4.44.1"
  },
  "resolutions": {
    "lru-cache": "5.1.1",
    "glob": "7.2.3",
    "babel-loader": "8.3.0",
    "nopt": "7.2.1"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "browser": true,
      "node": true
    },
    "plugins": [
      "vue",
      "prettier"
    ],
    "extends": [
      "plugin:vue/essential",
      "@vue/prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "warn",
        {
          "#": "prettier config in here :)",
          "semi": false,
          "singleQuote": true,
          "trailingComma": "none",
          "no-unused-vars": false,
          "vue/require-v-for-key": false,
          "vue/no-mutating-props": false,
          "vue/no-unused-vars": false,
          "vue/no-dupe-v-else-if": false
        }
      ],
      "vue/no-use-v-if-with-v-for": "off",
      "vue/no-mutating-props": "off",
      "vue/no-unused-vars": "off",
      "vue/no-dupe-v-else-if": "off"
    },
    "parserOptions": {
      "parser": "babel-eslint",
      "ecmaVersion": 6,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "overrides": [
      {
        "files": [
          "**/__tests__/*.{j,t}s?(x)",
          "**/tests/unit/**/*.spec.{j,t}s?(x)"
        ],
        "env": {
          "jest": true
        }
      }
    ]
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ]
}
